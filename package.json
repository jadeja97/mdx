{
  "name": "@jadeja/docs",
  "description": "an opinionated documentation framework",
  "version": "1.0.0-alpha.0",
  "type": "module",
  "exports": {
    "./configs/oxfmt": {
      "types": "./dist/src/configs/oxfmt/index.d.ts",
      "import": "./dist/oxfmt.js",
      "default": "./dist/oxfmt.js",
      "require": "./dist/oxfmt.js"
    },
    "./configs/oxfmt/types": {
      "types": "./dist/src/configs/oxfmt/types.d.ts"
    },
    "./types": {
      "types": "./dist/src/types/index.d.ts"
    }
  },
  "scripts": {
    "prepare": "husky",
    "check": "tsc && oxfmt --check --disable-nested-config && oxlint --disable-nested-config",
    "fix": "oxlint --fix --disable-nested-config && oxfmt --disable-nested-config",
    "build": "vite build",
    "publish-it": "pnpm publish --tag alpha --access public --no-git-checks"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^6.0.3",
    "unplugin-dts": "^1.0.0",
    "vite": "^8.0.8"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.5.0",
    "@next/third-parties": "^16.2.7",
    "@types/node": "^24.6.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "front-matter": "^4.0.2",
    "minisearch": "^7.2.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "mdx",
    "next",
    "docs",
    "documentation",
    "framework",
    "jadeja"
  ],
  "files": [
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "dist"
  ],
  "homepage": "https://github.com/JadejaHQ/docs",
  "bugs": "https://github.com/JadejaHQ/docs/issues",
  "license": "MIT",
  "author": {
    "name": "Pradipsinh Jadeja",
    "email": "224366804+jadeja97@users.noreply.github.com",
    "url": "https://x.com/jadeja97_"
  },
  "contributors": [
    {
      "name": "Pradipsinh Jadeja",
      "email": "224366804+jadeja97@users.noreply.github.com",
      "url": "https://x.com/jadeja97_"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JadejaHQ/docs.git"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10",
    "turbo": ">=2",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "bun": "please-use-pnpm"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=10",
      "onFail": "error"
    }
  },
  "dependencies": {
    "@jadeja/ts": "1.0.0-alpha.0"
  }
}
