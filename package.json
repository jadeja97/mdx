{
  "name": "@jadeja/docs",
  "description": "an opinionated documentation framework",
  "version": "1.0.0-alpha.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "import": "./dist/components/*.js",
      "default": "./dist/components/*.js"
    },
    "./default-config": {
      "types": "./dist/conifg/index.d.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js",
      "default": "./dist/hooks/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    },
    "./markdown/*": {
      "types": "./dist/markdown/*.d.ts",
      "import": "./dist/markdown/*.js",
      "default": "./dist/markdown/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "prepare": "husky",
    "check": "tsc && oxfmt --check --disable-nested-config && oxlint --disable-nested-config",
    "fix": "oxlint --fix --disable-nested-config && oxfmt --disable-nested-config",
    "build": "pnpm check && vite build",
    "publish-it": "pnpm build && pnpm publish --tag alpha --access public --no-git-checks"
  },
  "dependencies": {
    "@jadeja/ts": "1.0.0-alpha.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "front-matter": "^4.0.2",
    "github-slugger": "^2.0.0",
    "minisearch": "^7.2.0",
    "next-themes": "^0.4.6",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.6.2",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/webpack": "^5.28.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^6.0.3",
    "unplugin-dts": "^1.0.0",
    "vite": "^8.0.8"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.5.0",
    "@next/mdx": "^16.2.2",
    "@next/third-parties": "^16.2.7",
    "next": "^16.2.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "keywords": [
    "mdx",
    "next",
    "docs",
    "documentation",
    "framework",
    "jadeja"
  ],
  "files": [
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "dist"
  ],
  "homepage": "https://github.com/JadejaHQ/docs",
  "bugs": "https://github.com/JadejaHQ/docs/issues",
  "license": "MIT",
  "author": {
    "name": "Pradipsinh Jadeja",
    "email": "224366804+jadeja97@users.noreply.github.com",
    "url": "https://x.com/jadeja97_"
  },
  "contributors": [
    {
      "name": "Pradipsinh Jadeja",
      "email": "224366804+jadeja97@users.noreply.github.com",
      "url": "https://x.com/jadeja97_"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JadejaHQ/docs.git"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10",
    "turbo": ">=2",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "bun": "please-use-pnpm"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24",
      "onFail": "error"
    },
    "packageManager": {
      "name": "pnpm",
      "version": ">=10",
      "onFail": "error"
    }
  }
}
